# Copy to mesh.openclaw.env on dev-pc (do not commit mesh.openclaw.env).
# Used by smoke:phase14 and optional demo:preflight step.

# phone-a Tailscale IP (defaults to PHONE_A_IP from mesh.env)
OPENCLAW_PHONE_A_IP=100.120.187.10

# Gateway port on phone-a
OPENCLAW_PORT=18789

# 1 = gateway binds loopback only; smoke uses SSH tunnel from dev-pc
OPENCLAW_SSH_TUNNEL=1

# Local port for tunnel / direct curl from dev-pc
OPENCLAW_LOCAL_PORT=18789

# Set to 1 after openclaw onboard + start on phone-a (enables smoke:phase14 in demo:preflight)
OPENCLAW_ENABLED=0
