# OpenClaw on phone-a — non-secret config.
# Copy to ~/phone-lab/openclaw-phone-a.env on device.
# Secrets (API keys, bot tokens) go in ~/.openclaw/ via openclaw onboard — not here.

# Gateway port (must not conflict with 4000/4010)
OPENCLAW_PORT=18789

# native | proot
OPENCLAW_INSTALL_MODE=native

# Bind mode: loopback | tailnet | lan | auto (not raw IP — see docs.openclaw.ai)
OPENCLAW_BIND=loopback

# tmux session name
OPENCLAW_TMUX_SESSION=oc

# Workspace path (git clone or copy from phone-lab openclaw-workspace/)
OPENCLAW_WORKSPACE=$HOME/openclaw-workspace

# Boot delay seconds (network ready)
PHONE_LAB_BOOT_SLEEP=30
