# Pull-deploy config for phone-b (copy to ~/phone-lab/pull-deploy.env).
# Requires GITHUB_TOKEN in ~/phone-lab/mesh.secrets.env (read-only PAT).

# Set to 1 after first manual deploy + token setup
PULL_DEPLOY_AGENTS_ENABLED=0

GITHUB_REPO=Ezrababait-2023/api-agents
RELEASE_TAG_PREFIX=phone-lab-agents-prod/
ASSET_NAME=agents-prod.tgz

# Optional overrides (defaults match api-agents-prod layout)
# PKG_DIR=$HOME/phone-lab/packages/api-agents-prod
# RESTART_SCRIPT=$HOME/phone-lab/packages/api-agents-prod/scripts/termux/phone-b/restart-agents-prod.sh
