PORT=4010

NODE_ENV=production



# PostgreSQL (local on phone-b)

DB_TYPE=postgres

DB_HOST=127.0.0.1

DB_PORT=5432

DB_USERNAME=admin

DB_PASSWORD=password123

DB_NAME=agents

DB_SYNCHRONIZE=true



# RabbitMQ — proot Debian on phone-b (127.0.0.1:5672)

RABBIT_MQ_URI=amqp://rmuser:password123@127.0.0.1:5672



# LLM — live Gemini (Phase 10 smoke-full)

# GEMINI_API_KEY injected from mesh.secrets.env by apply-phone-b-env.ps1

LLM_STUB=false

GEMINI_API_KEY=



# Memory limit for health/ready (bytes) — 240 MB

HEAP_MAX_SIZE=251658240



# Stubs kept for smoke-local --full (GSC/SERP/crawl paths use stubs even in full mode)

GSC_STUB=true

SERP_STUB=true

SEO_MONITOR_CRON_ENABLED=false

SEO_MONITOR_SITE_URL=https://ezrababait.co.il/



# Content service (api-content-prod — see mesh.content.env / CURRENT-ARCHITECTURE.md)

CONTENT_INTERNAL_URL=http://127.0.0.1:4004

INTERNAL_SERVICE_TOKEN=phone-lab-internal-token



COMPETITOR_CRAWL_STUB=true

