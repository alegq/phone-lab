# OpenClaw on prod server — non-secret config reference.
# Secrets: ~/.openclaw/openclaw.json, systemd Environment=, or vault — not in git.

OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_WORKSPACE=$HOME/openclaw-workspace

# Telegram sandbox bot naming: ezra-lab-srv-*
# Do not reuse phone-a bot token (ezra-lab-phone-a-*)

# Health:
#   curl -s http://127.0.0.1:18789/health
#   openclaw doctor
#   systemctl --user status openclaw-gateway

# Runbook: docs/OPENCLAW-SERVER-RUNBOOK.md
