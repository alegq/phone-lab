PORT=4000
NODE_ENV=development

# If you use same-origin /api/* via Cloudflare Worker on:
#   https://admin-phone.bufsa.com
# then browser Origin will be https://admin-phone.bufsa.com
ALLOWED_ORIGIN_DEV=https://admin-phone.bufsa.com
ALLOWED_ORIGIN_DEV_NGINX=https://admin-phone.bufsa.com
ALLOWED_ORIGIN_STAGE=https://admin-phone.bufsa.com
ALLOWED_ORIGIN_ADMIN_DEV=https://admin-phone.bufsa.com
ADMIN_ALLOW_LOCALHOST=false

# Joi-required stubs (unused until those services are deployed)
AUTH_SERVICE_URL=http://127.0.0.1:1
PROFILE_SERVICE_URL=http://127.0.0.1:1
MESSAGE_BOT_SERVICE_URL=http://127.0.0.1:1
WHATSAPP_SERVICE_URL=http://127.0.0.1:1
MARKETING_INTERNAL_URL=http://100.103.183.36:4008
# fallback doc: http://100.120.187.10:4008

# phone-b backends (private network)
AGENTS_INTERNAL_URL=http://100.103.183.36:4010
CONTENT_INTERNAL_URL=http://100.103.183.36:4004

# RabbitMQ on phone-b (required for Phase 11 admin flow)
RABBIT_MQ_URI_EZRABA=amqp://rmuser:password123@100.103.183.36:5672
RABBIT_MQ_URI_DRIVERS=amqp://rmuser:password123@100.103.183.36:5672

# JWT (Phase 11+)
JWT_SECRET=9da9e6e8fdc316dc156b3dc42588006c
JWT_EXPIRATION=180000

# OAuth placeholders (required non-empty for Nest bootstrap)
GOOGLE_CLIENT_ID=phone-lab-placeholder
GOOGLE_CLIENT_SECRET=phone-lab-placeholder
GOOGLE_CALLBACK=https://admin-phone.bufsa.com/api/auth/google/redirect
FACEBOOK_CLIENT_ID=phone-lab-placeholder
FACEBOOK_CLIENT_SECRET=phone-lab-placeholder
FACEBOOK_CALLBACK=https://admin-phone.bufsa.com/auth/facebook/redirect
FIREBASE_API_KEY=
GOOGLE_AUTH_REDIRECT_URI=https://admin-phone.bufsa.com

# Health heap limit (bytes)
HEAP_MAX_SIZE=805306368

