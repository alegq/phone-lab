PORT=4001
NODE_ENV=production

# Used by api-auth for redirects / CORS metadata (not enforced strictly in main.ts)
FRONTEND_SERVICE_DOMAIN=5173

# JWT (must match gateway JWT_SECRET)
JWT_SECRET=9da9e6e8fdc316dc156b3dc42588006c
JWT_EXPIRATION=180000

# OAuth placeholders (must be non-empty for Joi bootstrap; not used in Phase 11)
GOOGLE_CLIENT_ID=phone-lab-placeholder
GOOGLE_CLIENT_SECRET=phone-lab-placeholder
GOOGLE_CALLBACK=http://100.120.187.10:4000/api/auth/google/redirect
FACEBOOK_CLIENT_ID=phone-lab-placeholder
FACEBOOK_CLIENT_SECRET=phone-lab-placeholder
FACEBOOK_CALLBACK=http://100.98.162.107:3001/auth/facebook/redirect

# Firebase Identity Toolkit key (required for admin login flow)
# NOTE: in this lab we source it from ../api-auth/.env (user-approved) during deploy.
FIREBASE_API_KEY=

# PostgreSQL (local on phone-b)
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=password123
DB_NAME=auth
DB_SYNCHRONIZE=true

# RabbitMQ — proot Debian on phone-b (local)
RABBIT_MQ_URI=amqp://rmuser:password123@127.0.0.1:5672

